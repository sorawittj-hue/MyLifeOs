rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // All other collections (Health Data, Logs, etc.):
    // Enforce that the 'uid' field matches the authenticated user
    match /{collection}/{docId} {
      // Allow read if the document's uid matches the user's uid
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      
      // Allow create if they are setting the uid to their own
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      
      // Allow update/delete if the document already belongs to them
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
